{
  "name": "subagent-router",
  "version": "0.2.3",
  "description": "Route subagent work from primary coding agents to local, low-cost, or cloud model backends.",
  "homepage": "https://github.com/marikarX/subagent-router#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/marikarX/subagent-router.git"
  },
  "bugs": {
    "url": "https://github.com/marikarX/subagent-router/issues"
  },
  "keywords": [
    "codex",
    "subagent",
    "router",
    "deepseek",
    "ollama",
    "openai-compatible"
  ],
  "type": "commonjs",
  "bin": {
    "subagent-router": "bin/subagent-router.js",
    "sar": "bin/subagent-router.js"
  },
  "files": [
    "bin/",
    "src/",
    "!src/**/*.egg-info/",
    "!src/**/*.py[cod]",
